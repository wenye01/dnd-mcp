# LLM Configuration
# For Zhipu GLM, use:
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
#   LLM_MODEL=glm-4-flash
# For OpenAI, use:
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.openai.com/v1/
#   LLM_MODEL=gpt-4
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60

# Server Configuration
# Use mock:// for local testing without real server
SERVER_URL=mock://
MCP_SERVER_URL=mock://

# Redis Configuration
REDIS_HOST=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# HTTP Configuration
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Log Configuration
LOG_LEVEL=info
LOG_FORMAT=json
